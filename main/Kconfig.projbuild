menu "iFeel GPIO Configuration"

    config IFEEL_DS18B20_GPIO
        int "DS18B20 one-wire GPIO"
        default 7
        range 0 21
        help
            GPIO number for the DS18B20 temperature sensor data line.

    config IFEEL_IR_GPIO
        int "GREE IR transmitter GPIO"
        default 0
        range 0 21
        help
            GPIO number for the IR LED (GREE AC transmitter).

    config IFEEL_F1_BUTTON_GPIO
        int "F1 button GPIO"
        default 3
        range 0 21
        help
            GPIO number for the F1 button (toggles AC on/off).

    config IFEEL_F2_BUTTON_GPIO
        int "F2 button GPIO"
        default 4
        range 0 21
        help
            GPIO number for the F2 button (adjusts AC setpoint / limit config).

    config IFEEL_F3_BUTTON_GPIO
        int "F3 button GPIO"
        default 10
        range 0 21
        help
            GPIO number for the F3 button (toggles AC display light).

endmenu
